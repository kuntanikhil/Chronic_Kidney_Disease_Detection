								<bottomPen lineWidth="0.5"/>
								<rightPen lineWidth="0.5"/>
							</box>
							<textElement textAlignment="Right" verticalAlignment="Middle">
								<font isBold="true"/>
							</textElement>
							<textFieldExpression><![CDATA[$V{totalconcessionmeasure_adm_no_ALL}]]></textFieldExpression>
							<patternExpression><![CDATA[($P{mantissaValue}.equalsIgnoreCase("3"))?"#,##0.000":"#,##0.00"]]></patternExpression>
						</textField>
					</cellContents>
				</crosstabCell>
			</crosstab>
		</band>
	</summary>
</jasperReport>
