<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="feeInstallmentWisePaidDueReport" pageWidth="10000" pageHeight="1100" orientation="Landscape" columnWidth="9984" leftMargin="6" rightMargin="10" topMargin="24" bottomMargin="10" isSummaryWithPageHeaderAndFooter="true" isFloatColumnFooter="true" uuid="c183226c-99c8-4289-b338-8e3a208d780a">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.unit." value="pixel"/>
	<property name="net.sf.jasperreports.awt.ignore.missing.font" value="true"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="New Data Adapter "/>
	<property name="ireport.zoom" value="0.8264462809917368"/>
	<property name="ireport.x" value="43"/>
	<property name="ireport.y" value="0"/>
	<property name="net.sf.jasperreports.export.xls.freeze.row" value="7"/>
	<property name="net.sf.jasperreports.print.keep.full.text" value="true"/>
	<property name="net.sf.jasperreports.text.truncate.at.char=true" value="true"/>
	<property name="net.sf.jasperreports.legacy.element.stretch.enabled" value="true"/>
	<style name="Crosstab Data Text" hAlign="Center"/>
	<style name="default" isDefault="true"/>
	<parameter name="branchLogo" class="java.lang.String">
		<parameterDescription><![CDATA[]]></parameterDescription>
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="format" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="branchId" class="java.lang.Long"/>
	<parameter name="classId" class="java.lang.String"/>
	<parameter name="sectionId" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sessionId" class="java.lang.Long"/>
	<parameter name="noDueStatus" class="java.lang.Boolean"/>
	<parameter name="pendingDues" class="java.lang.Boolean"/>
	<parameter name="p1Cond" class="java.lang.String">
		<defaultValueExpression><![CDATA[("'-1'".equals($P{classId}) ? "" : " AND AST.CLASS_ID in( "+ $P{classId} +")" )]]></defaultValueExpression>
	</parameter>
	<parameter name="p2Cond" class="java.lang.String">
		<defaultValueExpression><![CDATA[("'-1'".equals($P{sectionId}) ? "" : " AND AST.SECTION_ID in( "+ $P{sectionId} +")" )]]></defaultValueExpression>
	</parameter>
	<parameter name="p3Cond" class="java.lang.String">
		<defaultValueExpression><![CDATA[(($P{noDueStatus} != null && $P{noDueStatus})||($P{pendingDues} != null && $P{pendingDues}) ? "WITH CTE AS ( " : "  " )]]></defaultValueExpression>
	</parameter>
	<parameter name="p4Cond" class="java.lang.String">
		<defaultValueExpression><![CDATA[($P{noDueStatus} != null && $P{noDueStatus} ? " ) SELECT CTE.*  FROM CTE  LEFT JOIN (SELECT  CTE.STUDENT_ID, sum(CTE.DUE) as finalDue from CTE group by CTE.STUDENT_ID) due on CTE.STUDENT_ID=due.STUDENT_ID  WHERE due.finalDue =0 " : "  " )]]></defaultValueExpression>
	</parameter>
	<parameter name="p5Cond" class="java.lang.String">
		<defaultValueExpression><![CDATA[($P{pendingDues} != null && $P{pendingDues} ? " ) SELECT CTE.*  FROM CTE  LEFT JOIN (SELECT  CTE.STUDENT_ID, sum(CTE.DUE) as finalDue from CTE group by CTE.STUDENT_ID) due on CTE.STUDENT_ID=due.STUDENT_ID  WHERE due.finalDue >0 " : "  " )]]></defaultValueExpression>
	</parameter>
	<parameter name="academicSessionId" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="status" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sessionNames" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="feeTypeIdCond" class="java.lang.String">
		<defaultValueExpression><![CDATA[("'-1'".equals($P{feeTypeId}) ? "" : " AND FD.FEE_TYPE_ID in( "+ $P{feeTypeId} +")" )]]></defaultValueExpression>
	</parameter>
	<parameter name="feeTypeIdCond2" class="java.lang.String">
		<defaultValueExpression><![CDATA[("'-1'".equals($P{feeTypeId}) ? "" : " AND FI.fee_type_id in( "+ $P{feeTypeId} +")" )]]></defaultValueExpression>
	</parameter>
	<parameter name="feeTypeId" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="feeInstallmentsName" class="java.lang.String"/>
	<parameter name="installmentIdCond" class="java.lang.String">
		<defaultValueExpression><![CDATA[("'-1'".equals($P{installmentId}) ? "" : " AND FSI.FEE_SCHEDULE_INSTALLMENT_ID in( "+ $P{installmentId} +")" )]]></defaultValueExpression>
	</parameter>
	<parameter name="installmentIdCond2" class="java.lang.String">
		<defaultValueExpression><![CDATA[("'-1'".equals($P{installmentId}) ? "" : " AND FI.FEE_SCHEDULE_INSTALLMENT_ID in( "+ $P{installmentId} +")" )]]></defaultValueExpression>
	</parameter>
	<parameter name="installmentIdCond3" class="java.lang.String">
		<defaultValueExpression><![CDATA[("'-1'".equals($P{installmentId}) ? "" : " AND FD.FEE_SCHEDULE_INSTALLMENT_ID in( "+ $P{installmentId} +")" )]]></defaultValueExpression>
	</parameter>
	<parameter name="installmentId" class="java.lang.String"/>
	<parameter name="classNames" class="java.lang.String"/>
	<parameter name="generatedBy" class="java.lang.String"/>
	<parameter name="schoolName" class="java.lang.String"/>
	<parameter name="schoolAddress" class="java.lang.String"/>
	<parameter name="feeTypesName" class="java.lang.String"/>
	<parameter name="timezone" class="java.lang.String"/>
	<parameter name="generatedOn" class="java.lang.String"/>
	<parameter name="mantissaLength" class="java.lang.String"/>
	<parameter name="orderBy" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="orderByVal" class="java.lang.String">
		<defaultValueExpression><![CDATA[(
            "'class'".equals($P{orderBy})
            ? "ORDER BY CL.SEQ_NO,SC.SECTION_ID"
            : ("'studentName'".equals($P{orderBy})
                ? "ORDER BY STUDENT_NAME,ST.ADMISSION_NO,ACS.START_DATE,CL.SEQ_NO,SC.NAME,2,FSI.FEE_SCHEDULE_INSTALLMENT_ID"
                : "ORDER BY CASE WHEN ST.ADMISSION_NO REGEXP '^[0-9]+$' THEN 1 ELSE 2 END, CAST(ST.ADMISSION_NO AS UNSIGNED) ASC,ST.ADMISSION_NO ASC")
        )]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[$P!{p3Cond}
    SELECT A.ADM_NO,
	A.STUDENT_NAME,A.PRIMARY_CONTACT,A.SECTION_NAME,A.CLASS_SECTION,A.FEE_TYPE_NAME,A.BILLED,A.PAID,A.FEE_SCHEDULE_INSTALLMENT_ID,IFNULL(A.INSTALLMENT_NAME,'NA') AS INSTALLMENT_NAME,
	A.DUE,A.FEE_TYPE_ID,A.STUDENT_ID,A.STATUS,A.DURATION,A.CLASS_SEQ_NO,A.RECEIPT_NUMBER,A.FINE_AMOUNT,A.DUE_FINE_AMOUNT,A.CBF_FINE_AMOUNT, A.CONCESSION_AMOUNT,A.PAYMENT_DATE,(@r:=@r+1) AS SEQ,A.FEE_CATEGORY ,A.PRIMARY_CONTACT_NUMBER,
	IF(@STD_ID<>A.CLASS_ID, A.FINE_AMOUNT, 0) AS PAID_FINE,IF(@STD_ID<>A.CLASS_ID, A.DUE_FINE_AMOUNT, 0) AS DUE_FINE
	,IF(@STD_ID<>A.CLASS_ID, A.CBF_FINE_AMOUNT, 0) AS CBF_FINE,@STD_ID:=IF(@STD_ID<>A.CLASS_ID, A.STUDENT_ID,@STD_ID),
	CONVERT(IF(@ADM_ID<>A.CLASS_ID, @S_NO:=@S_NO+1, @S_NO),UNSIGNED) AS S_NO,
	@ADM_ID:=IF(@ADM_ID<>A.CLASS_ID,A.CLASS_ID,@ADM_ID),A.CLASS_NAME as CLASS_NAME
	from(
		SELECT
		ST.ADMISSION_NO AS ADM_NO ,
		CONCAT_WS(' ', ST.FIRST_NAME ,ST.MIDDLE_NAME, ST.LAST_NAME)AS STUDENT_NAME,
		CONCAT_WS(' ',PR.FIRST_NAME,PR.MIDDLE_NAME,PR.LAST_NAME) AS PRIMARY_CONTACT,
		CL.NAME as CLASS_NAME,SC.NAME as SECTION_NAME,CL.CLASS_ID as CLASS_ID,
		CONCAT(CL.NAME,'-' ,SC.NAME) AS CLASS_SECTION,
		(CASE WHEN ACS.IF_CURRENT = 0 THEN CONCAT(FSI.NAME ,'(',ACS.DURATION , ')') ELSE FSI.NAME END ) AS INSTALLMENT_NAME,
		FT.FEE_TYPE_NAME AS FEE_TYPE_NAME,
		FSI.FEE_SCHEDULE_INSTALLMENT_ID as FEE_SCHEDULE_INSTALLMENT_ID,
		SUM(L.ORIGINAL_DUE-L.CONCESSION) AS BILLED,
		SUM((L.ORIGINAL_DUE-L.BALANCE-L.CONCESSION)) as PAID,
		SUM(L.BALANCE) as DUE,
		FT.FEE_TYPE_ID,AST.STUDENT_ID,AST.STATUS ,ACS.DURATION ,CL.SEQ_NO AS CLASS_SEQ_NO,
		B.RECEIPT_NUMBER,
		IFNULL(D.fineAmount,0) AS FINE_AMOUNT,
		IFNULL(FINE.FINE,0) AS DUE_FINE_AMOUNT,
		IFNULL(CBF.CHEQUE_BOUNCE_FINE,0) AS CBF_FINE_AMOUNT,
		IFNULL(C.concessionAmount,0) AS CONCESSION_AMOUNT,
		B.PAYMENT_DATE,
		SCCT.PRIMARY_PHONE AS PRIMARY_CONTACT_NUMBER,
		 FCAT.FEE_CATEGORY_NAME AS FEE_CATEGORY
		FROM LEDGER L
		JOIN FEE_DUE FD ON L.FEE_DUE_ID =  FD.FEE_DUE_ID
		LEFT JOIN FEE_SCHEDULE_INSTALLMENT FSI ON FSI.FEE_SCHEDULE_INSTALLMENT_ID=L.FEE_SCHEDULE_INSTALLMENT_ID
		JOIN FEE_TYPE FT ON FT.FEE_TYPE_ID=L.FEE_TYPE_ID
		JOIN ACADEMIC_STUDENT AST ON (AST.STUDENT_ID = L.STUDENT_ID) AND (L.BRANCH_ID = AST.BRANCH_ID) AND (L.ACADEMIC_SESSION_ID = AST.ACADEMIC_SESSION_ID)
		JOIN STUDENT ST ON (ST.STUDENT_ID = L.STUDENT_ID)  AND ( ST.BRANCH_ID = L.BRANCH_ID )
		JOIN (
			SELECT ACS.*
     		FROM ACADEMIC_SESSION ACS
      		JOIN (
      			SELECT ACADEMIC_SESSION_ID from ACADEMIC_SESSION where ACADEMIC_SESSION_ID in($P!{academicSessionId})
      		  ) T ON T.ACADEMIC_SESSION_ID = ACS.ACADEMIC_SESSION_ID
      		 ) ACS on ACS.ACADEMIC_SESSION_ID = AST.ACADEMIC_SESSION_ID
		JOIN CLASS CL on (AST.CLASS_ID  = CL.CLASS_ID ) and (AST.BRANCH_ID  = CL.BRANCH_ID )  AND (AST.ACADEMIC_SESSION_ID = CL.ACADEMIC_SESSION_ID )
		JOIN SECTION SC on  (AST.SECTION_ID = SC.SECTION_ID ) and (AST.BRANCH_ID = SC.BRANCH_ID) AND (AST.ACADEMIC_SESSION_ID = SC.ACADEMIC_SESSION_ID )
		LEFT JOIN STUDENT_RELATION SR ON (ST.PRIMARY_CONTACT_ID=SR.STUDENT_RELATION_ID) AND ( ST.BRANCH_ID = SR.BRANCH_ID )
		LEFT JOIN PARENT PR ON (SR.PARENT_ID = PR.PARENT_ID) AND (SR.BRANCH_ID = PR.BRANCH_ID)
		LEFT JOIN STUDENT_CONTACT SCCT ON (SCCT.STUDENT_CONTACT_ID = PR.STUDENT_CONTACT_ID) AND (SCCT.BRANCH_ID = PR.BRANCH_ID)
		LEFT JOIN FEE_CATEGORY_STUDENT FCATS ON  (FCATS.STUDENT_ID = FD.STUDENT_ID) AND (FCATS.BRANCH_ID = FD.BRANCH_ID ) AND (FCATS.ACADEMIC_SESSION_ID = FD.ACADEMIC_SESSION_ID) AND  FCATS.STATUS IN ("Active")
		LEFT JOIN FEE_CATEGORY FCAT ON (FCAT.FEE_CATEGORY_ID = FCATS.FEE_CATEGORY_ID) AND (FCATS.BRANCH_ID = FCAT.BRANCH_ID ) AND (FCATS.ACADEMIC_SESSION_ID = FCAT.ACADEMIC_SESSION_ID)
		LEFT JOIN  (
			SELECT FT.FEE_TYPE_ID,CL.CLASS_ID,FD.FEE_SCHEDULE_INSTALLMENT_ID,GROUP_CONCAT(DISTINCT FRLI.RECEIPT_NUMBER order by FRLI.RECEIPT_NUMBER SEPARATOR ', ') as RECEIPT_NUMBER,
	    	GROUP_CONCAT(DISTINCT DATE_FORMAT(CONVERT_TZ(IFNULL(PAYMENT_DATE,R.RECEIPT_DATE),'Asia/Kolkata','$P!{timezone}'),'%d-%b-%Y') order by CLI.PAYMENT_DATE SEPARATOR ', ') as PAYMENT_DATE,
	   		FRLI.STUDENT_ID
		    FROM FEE_RECEIPT R
		    JOIN FEE_RECEIPT_LINE_ITEM FRLI ON FRLI.RECEIPT_ID=R.RECEIPT_ID
		    JOIN FEE_DUE FD ON FD.FEE_DUE_ID=FRLI.FEE_DUE_ID
		    JOIN FEE_TYPE FT ON FT.FEE_TYPE_ID=FD.FEE_TYPE_ID
		    JOIN ACADEMIC_STUDENT AST ON AST.STUDENT_ID = FD.STUDENT_ID AND AST.BRANCH_ID = FD.BRANCH_ID AND AST.ACADEMIC_SESSION_ID = FD.ACADEMIC_SESSION_ID
		    JOIN CLASS CL ON AST.CLASS_ID = CL.CLASS_ID AND AST.BRANCH_ID = CL.BRANCH_ID AND AST.ACADEMIC_SESSION_ID = CL.ACADEMIC_SESSION_ID
		    LEFT JOIN COLLECTION CLI ON (CLI.COLLECTION_ID = R.COLLECTION_ID)  AND (CLI.DUES_ACADEMIC_SESSION_ID = R.DUES_ACADEMIC_SESSION_ID) AND (CLI.BRANCH_ID = R.BRANCH_ID)
		    WHERE FD.BRANCH_ID=$P!{branchId}
		    AND FD.ACADEMIC_SESSION_ID in ($P!{academicSessionId})
		    AND COLLECTION_TYPE not in ('FEE_TYPE_BASED_FINE','CHEQUE_BOUNCED_FINE','FINE_WRITE_OFF','INSTALLMENT_BASED_FINE')
		    AND (R.STATUS  = 'Active' or (R.STATUS  = 'Fee_Category_Change' AND R.RECEIPT_TYPE = 'Fee_Category_Change_Partially_Reallocated'))
		    GROUP BY FRLI.DUES_ACADEMIC_SESSION_ID,CL.CLASS_ID,FT.FEE_TYPE_ID,FD.FEE_SCHEDULE_INSTALLMENT_ID
	  	  ) B ON B.FEE_TYPE_ID=FT.FEE_TYPE_ID AND B.CLASS_ID=CL.CLASS_ID and B.FEE_SCHEDULE_INSTALLMENT_ID=FSI.FEE_SCHEDULE_INSTALLMENT_ID
		LEFT JOIN (
			SELECT
			FD.FEE_SCHEDULE_INSTALLMENT_ID,FD.FEE_TYPE_ID,CL.CLASS_ID,
		    FRLI.STUDENT_ID,
			SUM(IF(COLLECTION_TYPE LIKE '%CONCESSION%'  and ((R.STATUS = 'Active') or ( R.STATUS IN ('Fee_Category_Change','Transport_Route_Change') AND
			(FRLI.RECEIPT_TYPE IN ('Collected',  'Refund_Initiated' , 'Refunded' ,'Partially_Refunded')))), -(FRLI.AMOUNT- FRLI.REFUNDED_AMOUNT),0)) as concessionAmount
	   		FROM FEE_RECEIPT R
            JOIN FEE_RECEIPT_LINE_ITEM FRLI ON FRLI.RECEIPT_ID=R.RECEIPT_ID
            JOIN FEE_DUE FD ON FD.FEE_DUE_ID=FRLI.FEE_DUE_ID
            JOIN ACADEMIC_STUDENT AST ON AST.STUDENT_ID = FD.STUDENT_ID AND AST.BRANCH_ID = FD.BRANCH_ID AND AST.ACADEMIC_SESSION_ID = FD.ACADEMIC_SESSION_ID
            JOIN CLASS CL ON AST.CLASS_ID = CL.CLASS_ID AND AST.BRANCH_ID = CL.BRANCH_ID AND AST.ACADEMIC_SESSION_ID = CL.ACADEMIC_SESSION_ID
            LEFT JOIN FEE_SCHEDULE_INSTALLMENT  FSI ON FSI.FEE_SCHEDULE_INSTALLMENT_ID=FD.FEE_SCHEDULE_INSTALLMENT_ID
	        LEFT JOIN COLLECTION CLI ON (CLI.COLLECTION_ID = R.COLLECTION_ID)  AND (CLI.DUES_ACADEMIC_SESSION_ID = R.DUES_ACADEMIC_SESSION_ID) AND (CLI.BRANCH_ID = R.BRANCH_ID)
            WHERE FD.BRANCH_ID=$P!{branchId}
	  		AND FD.ACADEMIC_SESSION_ID IN ($P!{academicSessionId})
           	AND (R.STATUS  = 'Active' or (R.STATUS  = 'Fee_Category_Change' AND R.RECEIPT_TYPE = 'Fee_Category_Change_Partially_Reallocated'))
           	GROUP BY FRLI.DUES_ACADEMIC_SESSION_ID,CL.CLASS_ID,FSI.FEE_SCHEDULE_INSTALLMENT_ID,FD.FEE_TYPE_ID
     	 )C ON C.FEE_SCHEDULE_INSTALLMENT_ID = FSI.FEE_SCHEDULE_INSTALLMENT_ID AND C.FEE_TYPE_ID= FT.FEE_TYPE_ID AND  C.CLASS_ID=CL.CLASS_ID
     	 LEFT JOIN (
			SELECT
		    FRLI.STUDENT_ID,
		    FRLI.ACADEMIC_SESSION_ID,
		    FRLI.BRANCH_ID,
		    CL.CLASS_ID,
		    FFFDM.FEE_SCHEDULE_INSTALLMENT_ID,
		    FD.FEE_TYPE_ID,
		    SUM(IF(FRLI.COLLECTION_TYPE in ('FEE_TYPE_BASED_FINE','CHEQUE_BOUNCED_FINE','INSTALLMENT_BASED_FINE','FINE_WRITE_OFF') and ((R.STATUS = 'Active') or ( R.STATUS IN ('Fee_Category_Change','Transport_Route_Change')
		    AND (FRLI.RECEIPT_TYPE IN ('Collected',  'Refund_Initiated' , 'Refunded' ,'Partially_Refunded')))), FRLI.AMOUNT - FRLI.REFUNDED_AMOUNT ,0)) AS fineAmount
			FROM FEE_RECEIPT R
			JOIN FEE_RECEIPT_LINE_ITEM FRLI ON FRLI.RECEIPT_ID=R.RECEIPT_ID
			join ACADEMIC_STUDENT AST on AST.STUDENT_ID = FRLI.STUDENT_ID and AST.ACADEMIC_SESSION_ID = FRLI.ACADEMIC_SESSION_ID and AST.BRANCH_ID = FRLI.BRANCH_ID
			join CLASS CL on AST.CLASS_ID = CL.CLASS_ID and AST.BRANCH_ID = CL.BRANCH_ID and AST.ACADEMIC_SESSION_ID = CL.ACADEMIC_SESSION_ID
			left join FEE_DUE FD on FD.FEE_DUE_ID = FRLI.FEE_DUE_ID
			left join FEE_FINE_FEE_DUE_MAPPING FFFDM on FRLI.FEE_FINE_FEE_DUE_MAPPING_ID = FFFDM.FEE_FINE_FEE_DUE_MAPPING_ID
			WHERE FRLI.BRANCH_ID =$P!{branchId}
			AND FRLI.DUES_ACADEMIC_SESSION_ID in ($P!{branchId})
			AND (R.STATUS  = 'Active' or (R.STATUS  = 'Fee_Category_Change' AND R.RECEIPT_TYPE = 'Fee_Category_Change_Partially_Reallocated'))
			group by CL.CLASS_ID, FFFDM.FEE_SCHEDULE_INSTALLMENT_ID, FD.FEE_TYPE_ID
		)  D on D.CLASS_ID = CL.CLASS_ID AND D.FEE_SCHEDULE_INSTALLMENT_ID=FSI.FEE_SCHEDULE_INSTALLMENT_ID
		LEFT JOIN (SELECT  STUDENT_ID, SUM(FINE) AS FINE, CLASS_ID, FEE_SCHEDULE_INSTALLMENT_ID, FEE_TYPE_ID FROM (
				SELECT FFDM.STUDENT_ID ,( CASE WHEN SUM(FFDM.AMOUNT) IS NULL THEN 0 ELSE SUM(FFDM.AMOUNT) END )  AS FINE ,CL.CLASS_ID,
				FSI.FEE_SCHEDULE_INSTALLMENT_ID, FD.FEE_TYPE_ID
				FROM  FEE_FINE_FEE_DUE_MAPPING FFDM
				join ACADEMIC_STUDENT AST on AST.STUDENT_ID = FFDM.STUDENT_ID and AST.ACADEMIC_SESSION_ID = FFDM.ACADEMIC_SESSION_ID and AST.BRANCH_ID = FFDM.BRANCH_ID
				join CLASS CL on AST.CLASS_ID = CL.CLASS_ID and AST.BRANCH_ID = CL.BRANCH_ID and AST.ACADEMIC_SESSION_ID = CL.ACADEMIC_SESSION_ID
				join FEE_DUE FD on FD.FEE_DUE_ID = FFDM.FEE_DUE_ID and FD.ACADEMIC_SESSION_ID = FFDM.ACADEMIC_SESSION_ID and FD.BRANCH_ID = FFDM.BRANCH_ID
				join FEE_SCHEDULE_INSTALLMENT FSI on FD.FEE_SCHEDULE_INSTALLMENT_ID = FSI.FEE_SCHEDULE_INSTALLMENT_ID and FD.ACADEMIC_SESSION_ID = FSI.ACADEMIC_SESSION_ID and FD.BRANCH_ID = FSI.BRANCH_ID
				WHERE FFDM.BRANCH_ID=$P{branchId}
				AND FFDM.ACADEMIC_SESSION_ID  in ($P!{academicSessionId)
				AND FFDM.FEE_DUE_ID IS NOT NULL
				$P!{installmentIdCond}
				$P!{feeTypeIdCond}
				$P!{p1Cond}
				$P!{p2Cond}
				AND FFDM.STATUS in ('Pending', 'Pending_Against_Paid_Fee_Dues')
				GROUP BY CL.CLASS_ID,FSI.FEE_SCHEDULE_INSTALLMENT_ID, FD.FEE_TYPE_ID
			UNION
				SELECT STUDENT_ID , SUM(FINE) AS FINE , CLASS_ID, FEE_SCHEDULE_INSTALLMENT_ID, FEE_TYPE_ID
				FROM(
					SELECT FFDM.STUDENT_ID ,CL.CLASS_ID,( CASE WHEN (FFDM.AMOUNT) IS NULL THEN 0 ELSE  (FFDM.AMOUNT) END )  AS FINE,
					 FI.FEE_SCHEDULE_INSTALLMENT_ID, FI.FEE_TYPE_ID,FFDM.STATUS
			 		 FROM FEE_FINE_FEE_DUE_MAPPING FFDM
					 join ACADEMIC_STUDENT AST on AST.STUDENT_ID = FFDM.STUDENT_ID and AST.ACADEMIC_SESSION_ID = FFDM.ACADEMIC_SESSION_ID and AST.BRANCH_ID = FFDM.BRANCH_ID and AST.STATUS = 'Active'
					 join CLASS CL on AST.CLASS_ID = CL.CLASS_ID and AST.BRANCH_ID = CL.BRANCH_ID and AST.ACADEMIC_SESSION_ID = CL.ACADEMIC_SESSION_ID
					 join FEE_INSTALLMENT FI on FFDM.FEE_SCHEDULE_INSTALLMENT_ID = FI.FEE_SCHEDULE_INSTALLMENT_ID and FFDM.ACADEMIC_SESSION_ID = FI.ACADEMIC_SESSION_ID and FFDM.BRANCH_ID = FI.BRANCH_ID
			 		 WHERE FFDM.BRANCH_ID= $P{branchId}
			 		 AND FFDM.ACADEMIC_SESSION_ID in ( $P!{academicSessionId})
			 		 AND FFDM.FEE_DUE_ID IS NULL
			  		$P!{feeTypeIdCond2}
			  		$P!{installmentIdCond2}
					$P!{p1Cond}
					$P!{p2Cond}
					AND FFDM.STATUS in ('Pending', 'Pending_Against_Paid_Fee_Dues')
			 		GROUP BY CL.CLASS_ID, FI.FEE_SCHEDULE_INSTALLMENT_ID, FI.FEE_TYPE_ID
			 	)A
			 GROUP BY CLASS_ID, FEE_SCHEDULE_INSTALLMENT_ID, FEE_TYPE_ID
			 ) A
			GROUP BY CLASS_ID, FEE_SCHEDULE_INSTALLMENT_ID, FEE_TYPE_ID
		)FINE ON FINE.CLASS_ID=CL.CLASS_ID AND FINE.FEE_SCHEDULE_INSTALLMENT_ID=FSI.FEE_SCHEDULE_INSTALLMENT_ID AND FINE.FEE_TYPE_ID=FT.FEE_TYPE_ID
		LEFT JOIN(
					select FLI.STUDENT_ID , A.CLASS_ID, (CASE WHEN SUM(FLI.AMOUNT) IS NULL THEN 0 ELSE SUM(FLI.AMOUNT) END ) -  (CASE WHEN A.PAID_FINE IS NULL THEN 0 ELSE  A.PAID_FINE END )   AS CHEQUE_BOUNCE_FINE, FLI.ACADEMIC_SESSION_ID  from FEE_INVOICE_LINE_ITEM FLI
				LEFT JOIN  (SELECT FP.STUDENT_ID ,  CL.CLASS_ID, SUM(FP.AMOUNT) AS PAID_FINE  FROM  FEE_PAYMENT FP
				JOIN ACADEMIC_STUDENT AST ON (AST.STUDENT_ID = FP.STUDENT_ID ) AND ( FP.ACADEMIC_SESSION_ID = AST.ACADEMIC_SESSION_ID) AND (AST.BRANCH_ID = FP.BRANCH_ID )
				JOIN CLASS CL ON AST.CLASS_ID = CL.CLASS_ID AND AST.BRANCH_ID = CL.BRANCH_ID AND AST.ACADEMIC_SESSION_ID = CL.ACADEMIC_SESSION_ID
				JOIN  FEE_INVOICE_LINE_ITEM FLI ON(FLI.INVOICE_LINE_ITEM_ID = FP.INVOICE_LINE_ITEM_ID) AND ( FLI.BRANCH_ID = FP.BRANCH_ID ) AND ( FLI.ACADEMIC_SESSION_ID = FP.ACADEMIC_SESSION_ID)
				JOIN FEE_DUE FD ON (FD.FEE_DUE_ID = FLI.FEE_DUE_ID) AND (FD.BRANCH_ID = FLI.BRANCH_ID) AND (FD.ACADEMIC_SESSION_ID = FLI.ACADEMIC_SESSION_ID)
				WHERE FLI.BRANCH_ID = $P{branchId}
				AND FLI.ACADEMIC_SESSION_ID in ( $P!{academicSessionId})
				AND FLI.INVOICE_LINE_ITEM_TYPE  = 7 GROUP BY CL.CLASS_ID ) A ON (A.STUDENT_ID = FLI.STUDENT_ID)
				WHERE FLI.BRANCH_ID  = $P{branchId}
				AND FLI.ACADEMIC_SESSION_ID IN ($P!{academicSessionId})
				AND INVOICE_LINE_ITEM_TYPE  = 7
				GROUP BY A.CLASS_ID
			) CBF on CBF.CLASS_ID = CL.CLASS_ID
		WHERE L.BRANCH_ID=$P!{branchId}
		AND AST.STATUS in ($P!{status}) AND L.ORIGINAL_DUE > 0
		$P!{p1Cond}
		$P!{p2Cond}
		$P!{feeTypeIdCond}
		$P!{installmentIdCond}
		GROUP BY L.ACADEMIC_SESSION_ID,CL.CLASS_ID,FSI.FEE_SCHEDULE_INSTALLMENT_ID,FT.FEE_TYPE_ID
		order by CL.SEQ_NO
       ) A,
	(select @r:=0) as u,(SELECT @STD_ID:=0) AS TEMP_STD_ID,(select @S_NO := 0) as SNO,(select @ADM_ID:=0) as TEMP_ADM_ID
         $P!{p4Cond}
         $P!{p5Cond}]]>
	</queryString>
